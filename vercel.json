{
  "rewrites": [
    { "source": "/", "destination": "/app.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/amplipatio", "destination": "/app.html" },
    { "source": "/patio", "destination": "/app.html" }
  ],
  "headers": [
    {
      "source": "/app.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/app",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
