# App
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://banking:banking@localhost:5432/banking?schema=public

# JWT (API interna / operadores)
JWT_SECRET=troque-por-segredo-longo-aleatorio
JWT_EXPIRES_IN=8h

# Emissão de token só para testes (nunca em produção)
DEV_JWT_ENDPOINT=true

# Criptografia de client_id/client_secret em repouso (64 caracteres hex = 32 bytes)
CREDENTIALS_MASTER_KEY_HEX=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Banco Inter — URLs oficiais (sandbox UAT diferente; ver portal developers.inter.co)
INTER_OAUTH_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_API_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_TOKEN_PATH=/oauth/v2/token
INTER_EXTRATO_COMPLETO_PATH=/banking/v2/extrato/completo
INTER_EXTRATO_PATH=/banking/v2/extrato
INTER_SALDO_PATH=/banking/v2/saldo
INTER_DEFAULT_SCOPES=extrato.read cob.read webhook.read webhook.write

# mTLS — use PFX OU par certificado+chave (caminhos dentro do container ou host)
INTER_MTLS_PFX_PATH=/secrets/inter.pfx
INTER_MTLS_PASSPHRASE=
# INTER_MTLS_CERT_PATH=/secrets/inter.crt
# INTER_MTLS_KEY_PATH=/secrets/inter.key

# Webhook PIX — HMAC-SHA256(hex) do corpo bruto (alinhar com documentação oficial do callback)
INTER_WEBHOOK_HMAC_SECRET=
INTER_WEBHOOK_SIGNATURE_HEADER=x-inter-signature
# Somente desenvolvimento:
INTER_WEBHOOK_SKIP_VERIFY=true

# Quando não existir conta a receber vinculada ao txid, ainda assim registrar PixPayment:
WEBHOOK_DEFAULT_TENANT_ID=tenant-demo

# Rate limit
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# Extrato: janela máxima por requisição (API Inter: até 90 dias)
INTER_EXTRATO_MAX_DAYS=90
